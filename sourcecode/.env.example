# Copy to .env (gitignored). Dev defaults — all values are local/dummy.
#   cp .env.example .env && docker compose up

# ── Compose ─────────────────────────────────────────────
# selfhost-data → run Postgres + Redis as containers (dev default).
COMPOSE_PROFILES=selfhost-data
REGISTRY=ghcr.io/yourorg
IMAGE_TAG=dev

# ── Data (dev = containers via the selfhost-data profile) ──
POSTGRES_PASSWORD=localdev
DATABASE_URL=postgresql://agentpm:localdev@postgres:5432/agentpm
REDIS_URL=redis://redis:6379

# ── Keycloak (the API only VERIFIES tokens; KC owns credentials) ──
# NOTE (Stage B / auth): browser and API container must resolve Keycloak by the
# SAME hostname or the token `iss` won't match. Before wiring auth, add
#   127.0.0.1 keycloak
# to your /etc/hosts and switch the two URLs below to http://keycloak:8080.
# For Stage A (no token verification yet) localhost is fine.
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/agentpm
KEYCLOAK_API_AUDIENCE=agentpm-api
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=agentpm
KC_DB_PASSWORD=localdev
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KEYCLOAK_HOSTNAME=localhost

# ── API ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000

# ── Web (Vite — baked in at build time) ────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=agentpm
VITE_KEYCLOAK_CLIENT=agentpm-web
