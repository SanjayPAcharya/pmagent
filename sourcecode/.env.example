# Copy to .env (gitignored). Dev defaults — all values are local/dummy.
#   cp .env.example .env && docker compose up

# ── Compose ─────────────────────────────────────────────
# selfhost-data → run Postgres + Redis as containers (dev default).
COMPOSE_PROFILES=selfhost-data
REGISTRY=ghcr.io/yourorg
IMAGE_TAG=dev

# ── Data (dev = containers via the selfhost-data profile) ──
POSTGRES_PASSWORD=localdev
DATABASE_URL=postgresql://agentpm:localdev@postgres:5432/agentpm
REDIS_URL=redis://redis:6379

# ── Keycloak (the API only VERIFIES tokens; KC owns credentials) ──
# ISSUER_URL = what tokens carry as `iss` (browser-facing); validated as allowedIss.
# INTERNAL_URL = where the API fetches the realm's JWKS (reachable from the container).
# They can differ in dev — same realm keys regardless of hostname — so no /etc/hosts hack.
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/agentpm
KEYCLOAK_INTERNAL_URL=http://keycloak:8080/realms/agentpm
KEYCLOAK_API_AUDIENCE=agentpm-api
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=agentpm
KC_DB_PASSWORD=localdev
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KEYCLOAK_HOSTNAME=localhost

# ── Social IdPs (Phase 2.8.5) — register OAuth apps, then fill these in. ──
# Redirect URI per provider: http://localhost:8080/realms/agentpm/broker/<provider>/endpoint
# Empty → keycloak-init skips that provider (its button falls back to the Keycloak page).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── API ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000
# Read notifications older than this (days) are purged by the daily retention sweep.
RETENTION_NOTIFICATION_DAYS=90

# ── AI (optional, 3.8) — Amazon Bedrock ─────────────────
# Leave AI_PROVIDER empty → AI features are DISABLED (buttons show a
# disabled-with-reason tooltip; no image rebuild needed to toggle — edit + restart api).
# Enable: AI_PROVIDER=bedrock + credentials (dev: the IAM-user key below;
# prod: the EC2 instance role — leave the keys empty there).
# Model swap (e.g. to a Claude global.* profile) is just BEDROCK_MODEL_ID.
AI_PROVIDER=
BEDROCK_MODEL_ID=apac.amazon.nova-micro-v1:0
AWS_REGION=ap-south-1
AI_TIMEOUT_MS=30000
# Dev-only: scoped IAM user (bedrock:InvokeModel + Get/ListInferenceProfiles).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Web (Vite — baked in at build time) ────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=agentpm
VITE_KEYCLOAK_CLIENT=agentpm-web
