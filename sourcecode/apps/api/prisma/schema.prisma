// Phase 1 data models. Later phases add Ticket/Sprint/Agent* etc.
// See ../../../agentpm-plan/references/03-data-models.md for the full target schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  idpSub      String?     @unique // Keycloak subject — JIT-provisioned on first login (Stage B)
  email       String      @unique
  name        String
  avatarUrl   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  memberships OrgMember[]

  @@index([email])
}

model Organization {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String      @unique
  plan      PlanType    @default(FREE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  members   OrgMember[]
  projects  Project[]

  @@index([slug])
}

model OrgMember {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @db.Uuid
  userId       String       @db.Uuid
  role         OrgRole      @default(MEMBER)
  joinedAt     DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model Project {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String       @db.Uuid
  name          String
  slug          String
  description   String?
  defaultBranch String       @default("main")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, slug])
  @@index([orgId])
}

enum PlanType {
  FREE
  PRO
  TEAM
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}
