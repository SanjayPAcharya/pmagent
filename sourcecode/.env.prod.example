# Production env — copy to .env.prod on the box, fill the CHANGE_ME values, chmod 600.
# NEVER commit .env.prod. Self-hosted data on the box (selfhost-data profile).

# ── Compose ──
COMPOSE_PROFILES=selfhost-data
REGISTRY=ghcr.io/sanjaypacharya          # lowercase GHCR owner
IMAGE_TAG=latest                         # CI overrides with the commit SHA on each deploy

# ── Public domains / URLs ──
APP_DOMAIN=pmagent.sanjaykumarp.info
API_DOMAIN=api.pmagent.sanjaykumarp.info
AUTH_DOMAIN=auth.pmagent.sanjaykumarp.info
PUBLIC_APP_URL=https://pmagent.sanjaykumarp.info
ACME_EMAIL=sanjaykumarp041@gmail.com     # for Let's Encrypt

# ── Data (self-hosted Postgres/Redis on the box) ──
POSTGRES_PASSWORD=CHANGE_ME_STRONG_1
DATABASE_URL=postgresql://agentpm:CHANGE_ME_STRONG_1@postgres:5432/agentpm
REDIS_URL=redis://redis:6379
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=agentpm
KC_DB_PASSWORD=CHANGE_ME_STRONG_1        # must equal POSTGRES_PASSWORD (same DB user)

# ── Keycloak ──
KC_ADMIN=admin
KC_ADMIN_PASSWORD=CHANGE_ME_STRONG_2
KEYCLOAK_ISSUER_URL=https://auth.pmagent.sanjaykumarp.info/realms/agentpm
KEYCLOAK_INTERNAL_URL=http://keycloak:8080/realms/agentpm
KEYCLOAK_API_AUDIENCE=agentpm-api

# ── Social IdPs (optional — empty = that provider is skipped; email/password works) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── API ──
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
ALLOWED_ORIGINS=https://pmagent.sanjaykumarp.info

# ── Web (BUILD-TIME — CI bakes these into the web image; not read at runtime) ──
VITE_API_URL=https://api.pmagent.sanjaykumarp.info
VITE_WS_URL=wss://api.pmagent.sanjaykumarp.info
VITE_KEYCLOAK_URL=https://auth.pmagent.sanjaykumarp.info
VITE_KEYCLOAK_REALM=agentpm
VITE_KEYCLOAK_CLIENT=agentpm-web
